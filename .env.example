# ============================================================
# AgriWise AI – Environment Variables
# Copy to .env and fill in real values before deploying
# NEVER commit .env to version control
# ============================================================

# ── Database ──────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password_here

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password

# ── JWT ───────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_64_byte_random_hex_string
REFRESH_SECRET=generate_another_64_byte_random_hex_string

# ── External APIs ─────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweathermap_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Payments ──────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
STRIPE_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
MERCHANT_UPI_ID=yourname@ybl

# ── Frontend ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000

# ── SMS (OTP) ─────────────────────────────────────────────
# Uncomment whichever provider you use:
# MSG91_AUTH_KEY=your_msg91_key
# FAST2SMS_API_KEY=your_fast2sms_key
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1415xxxxxxx

# ── Storage ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── App ───────────────────────────────────────────────────
NODE_ENV=production
PORT=8000
